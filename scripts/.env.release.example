# Copy to scripts/.env.release (gitignored) and fill in once you have a paid
# Apple Developer account + an App Store Connect API key. See release-ios.sh.

# App Store Connect API key ID (10 chars), shown next to the key in ASC.
ASC_KEY_ID=XXXXXXXXXX

# Issuer ID (UUID) — App Store Connect → Users and Access → Integrations.
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Absolute path to the AuthKey_<ASC_KEY_ID>.p8 you downloaded (downloadable once).
ASC_KEY_PATH=/Users/kendalldale/.appstoreconnect/private_keys/AuthKey_XXXXXXXXXX.p8
